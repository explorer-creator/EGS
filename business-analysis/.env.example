# 商业决策智能分析 - 环境变量示例
# 复制为 .env 并填写实际值

# LLM API（智谱 / GPT-4 / 千问 等 OpenAI 兼容）
LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# iDME 数据底座（预留）
# IDME_BASE_URL=http://127.0.0.1:8003/rdm_xxx_app/services
# IDME_API_PREFIX=dynamic/api

# 大宗商品实时市价（铜、铝）
# COMMODITY_API_KEY=xxx
# COMMODITY_API_URL=https://api.api-ninjas.com/v1/commodityprice

# CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
