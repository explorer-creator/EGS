# Build outputs
node_modules/
dist/
dist-ssr/
target/
*.class
*.jar
*.war

# Large archives (keep artifacts/README.md; store zips outside Git or use Releases)
artifacts/*.zip
*.zip

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment（密钥勿入库；仅保留 *.example）
.env
.env.local
.env.*.local
# Vite 前端：忽略所有环境文件，例外 .env.example
front/.env
front/.env.*
!front/.env.example
# 其他子目录本地配置
A/.env
greengeneratesysteam/.env.local

# IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Office 打开文档时的临时锁文件，勿提交
~$*

# Frontend
front/node_modules/
front/dist/

# Proxy
proxy/target/
# 本地密钥（千问/高德等），勿提交
proxy/src/main/resources/application-local.yml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
